# .env.development  (local dev — backend running with python manage.py runserver)
VITE_API_URL=http://localhost:8000/api/v1

# .env.docker  (both running in Docker)
# VITE_API_URL=http://localhost/api/v1

# .env.production  (deployed server — replace with your real IP or domain)
# VITE_API_URL=http://YOUR_SERVER_IP/api/v1
